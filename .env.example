DISCORD_TOKEN=votre_token_bot
CLIENT_ID=id_application_discord_oauth2

# Optionnel : limiter les slash à ces serveurs (plusieurs : id1,id2). Vide = au démarrage, sync sur **chaque** serveur où le bot est (immédiat).
GUILD_ID=

# true = commandes * en texte + intent Message Content (à activer aussi sur le portail Discord → Bot)
# PREFIX_COMMANDS=true

